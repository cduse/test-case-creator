{
  "expo": {
    "name": "Test Case Creator",
    "slug": "test-case-creator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "testcasecreator",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1117"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1117"
      },
      "package": "com.testcasecreator.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Test Case Creator to record audio for voice input."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
